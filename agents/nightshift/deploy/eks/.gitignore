# Generated EKS dev secrets (worker/objects HMAC, MinIO + Postgres
# passwords). Local-only; never commit.
.eks-*-hmac
.eks-*-pass

# Terraform state, runtime caches, and operator-supplied tfvars under
# deploy/eks/terraform/. The .terraform.lock.hcl IS intentionally
# tracked (provider version pinning across operators).
terraform/.terraform/
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfvars
terraform/.tf-outputs.json
